# =========================================================================
# Web wrapper (obratka-worker) — переменные окружения
# Скопируй в .env (или .env.worker) и подставь реальные creds для своей среды.
# =========================================================================

# --- Core LLM (используется ядром analyze_payload_llm) ----------------------
OPENROUTER_API_KEY=sk-or-...

# --- AMQP (берём у админа PG) ----------------------------------------------
# Локально (docker-compose.full.yml PG): amqp://gateway:gateway_pwd@localhost:5672/
RABBIT_URL=amqp://gateway:gateway_pwd@rabbitmq:5672/

# --- S3-совместимое хранилище (MinIO во внутренней сети PG) -----------------
# Локально: http://localhost:9000  (creds: minioadmin/minioadmin)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=obratka-jobs

# --- HTTP status endpoint --------------------------------------------------
LLM_HTTP_PORT=8000

# --- Persisted job state (SQLite) ------------------------------------------
# В docker — пробросьте том на этот путь, чтобы /status переживал рестарт.
LLM_STATE_DB=data/job_state.sqlite

# --- Параллелизм между jobs ------------------------------------------------
# Сколько jobs обрабатывать одновременно (AMQP prefetch_count). По умолчанию 3.
# Каждый job внутри параллелит батчи своим пулом (PIPELINE__MAX_CONCURRENCY),
# поэтому пиковая нагрузка на OpenRouter ~ LLM_MAX_PARALLEL_JOBS × max_concurrency.
# Поднимайте с оглядкой на rate-limit OpenRouter.
LLM_MAX_PARALLEL_JOBS=3

# --- Прочее (наследуется ядром из существующего .env) -----------------------
LOG_LEVEL=INFO
LOGS_DIR=logs

# --- Централизованные логи в Seq (CLEF поверх HTTP) ------------------------
# Когда SEQ__ENABLED=true, loguru дополнительно шлёт логи в Seq на {SEQ__URL}/ingest/clef
# (тот же формат, что и Serilog у .NET-сервисов). При недоступности Seq приложение
# не падает — отправка best-effort в фоновом потоке.
#
# Seq в ТОЙ ЖЕ docker-сети, поэтому используем ВНУТРЕННИЙ адрес контейнера (как
# .NET-сервисы через Serilog: Seq__ServerUrl=http://seq:80), а не публичный
# logs.*.sslip.io — трафик не выходит наружу. Sink сам добавит /ingest/clef.
# SEQ__ENABLED=true
# SEQ__URL=http://seq:80           # внутренний адрес Seq (как Seq__ServerUrl у .NET)
# SEQ__API_KEY=<ingestion-key>     # ОБЯЗАТЕЛЕН: ingestion закрыт ключом (Seq__ApiKey)
# SEQ__LEVEL=INFO                  # минимальный уровень, который шлём в Seq
# SEQ__SERVICE=obratka-llm         # значение свойства service для фильтрации в Seq
# SEQ__TIMEOUT_S=5.0
#
# ВАЖНО: контейнер worker-а должен быть подключён к docker-сети, где живёт Seq
# (та же external-сеть PG, см. docker-compose networks). Иначе hostname `seq` не
# зарезолвится.

# --- DEV-only QA endpoint --------------------------------------------------
# Когда =true, поднимает ручку POST /qa/analyze для прогона пайплайна по
# локальному JSON без RabbitMQ + S3. В этом режиме AMQP/S3-переменные становятся
# опциональны: если RABBIT_URL/S3_* не заданы, AMQP-loop не запускается и сервис
# работает только как HTTP API.
# OBRATKA_QA_ENABLED=true
# LLM_QA_OUTPUT_DIR=qa_outputs
