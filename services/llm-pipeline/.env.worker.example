# =========================================================================
# Web wrapper (obratka-worker) — переменные окружения
# Скопируй в .env (или .env.worker) и подставь реальные creds для своей среды.
# =========================================================================

# --- Core LLM (используется ядром analyze_payload_llm) ----------------------
OPENROUTER_API_KEY=sk-or-...

# --- AMQP (берём у админа PG) ----------------------------------------------
# Локально (docker-compose.full.yml PG): amqp://gateway:gateway_pwd@localhost:5672/
RABBIT_URL=amqp://gateway:gateway_pwd@rabbitmq:5672/

# --- S3-совместимое хранилище (MinIO во внутренней сети PG) -----------------
# Локально: http://localhost:9000  (creds: minioadmin/minioadmin)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=obratka-jobs

# --- HTTP status endpoint --------------------------------------------------
LLM_HTTP_PORT=8000

# --- Persisted job state (SQLite) ------------------------------------------
# В docker — пробросьте том на этот путь, чтобы /status переживал рестарт.
LLM_STATE_DB=data/job_state.sqlite

# --- Прочее (наследуется ядром из существующего .env) -----------------------
LOG_LEVEL=INFO
LOGS_DIR=logs

# --- DEV-only QA endpoint --------------------------------------------------
# Когда =true, поднимает ручку POST /qa/analyze для прогона пайплайна по
# локальному JSON без RabbitMQ + S3. В этом режиме AMQP/S3-переменные становятся
# опциональны: если RABBIT_URL/S3_* не заданы, AMQP-loop не запускается и сервис
# работает только как HTTP API.
# OBRATKA_QA_ENABLED=true
# LLM_QA_OUTPUT_DIR=qa_outputs
