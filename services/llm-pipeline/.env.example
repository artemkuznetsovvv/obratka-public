# OpenRouter API key — обязателен
OPENROUTER_API_KEY=your_openrouter_api_key_here

# PostgreSQL connection (для шага 10 — БД и кэша; на этапе варианта A не используется)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/obratka

# Окружение
APP_ENV=dev
LOG_LEVEL=INFO
LOGS_DIR=logs

# Опциональные оверрайды через nested env vars (delimiter "__"):
# PIPELINE__MAX_CONCURRENCY=12
# PIPELINE__STEP2_BATCH_SIZE=15
# PIPELINE__STEP2_LOW_CONF_THRESHOLD=0.6
# PIPELINE__STEP22_MAX_CONCURRENCY=4

# ── Веса отзывов (time decay) ──────────────────────────────────────────────
# strategy: none | exp | linear | step
PIPELINE__WEIGHTING__ENABLED=true
PIPELINE__WEIGHTING__STRATEGY=exp
PIPELINE__WEIGHTING__HALF_LIFE_DAYS=90
PIPELINE__WEIGHTING__WEIGHT_FLOOR=0.05
PIPELINE__WEIGHTING__FRESH_WINDOW_DAYS=30

# ── Arize Phoenix (LLM-трейсинг) ───────────────────────────────────────────
PHOENIX__ENABLED=false
PHOENIX__OTLP_ENDPOINT=http://localhost:4318
PHOENIX__PROJECT_NAME=obratka-dev
# PHOENIX__API_KEY=

# ── HTML-отчёт (временная фича, легко выпиливается) ────────────────────────
REPORT__ENABLED=false
REPORT__OUTPUT_DIR=reports
REPORT__OPEN_IN_BROWSER=false
REPORT__MAX_SAMPLES_PER_STEP=20
REPORT__CHARTJS_OFFLINE=false

# ── Web wrapper (obratka-worker) ────────────────────────────────────────────
# RabbitMQ + S3 нужны для интеграции с Processing Gateway.
# Локально: amqp://gateway:gateway_pwd@localhost:5672/ + minio на :9000.
# RABBIT_URL=amqp://gateway:gateway_pwd@rabbitmq:5672/
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=obratka-jobs
# LLM_HTTP_PORT=8000
# LLM_STATE_DB=data/job_state.sqlite

# ── DEV-only QA endpoint ────────────────────────────────────────────────────
# Когда =true, поднимает ручку POST /qa/analyze для прогона пайплайна по
# локальному JSON без RabbitMQ + S3. В этом режиме AMQP/S3-переменные становятся
# опциональны: если RABBIT_URL/S3_* не заданы, AMQP-loop не запускается и сервис
# работает только как HTTP API.
# OBRATKA_QA_ENABLED=true
# LLM_QA_OUTPUT_DIR=qa_outputs
