{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TasksDb": "Data Source=/data/tasks.db"
  },
  "S3": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "obratka-jobs"
  },
  "Proxy": {
    "Servers": []
  },
  "RateLimiting": {
    "Sources": {
      "yandex": {
        "MaxConcurrentOrgs": 1,
        "MaxOrgsPerHour": 15,
        "DelayAfterOrgMinMs": 10000,
        "DelayAfterOrgMaxMs": 30000
      }
    }
  },
  "YandexMaps": {
    "CollectionMode": "BrowserScroll",
    "PageSize": 50,
    "MaxPages": 12,
    "DelayBetweenPagesMinMs": 2000,
    "DelayBetweenPagesMaxMs": 5000,
    "DelayBetweenOrgsMinMs": 10000,
    "DelayBetweenOrgsMaxMs": 30000,
    "MaxRetries": 3,
    "CaptchaSolverApiKey": "",
    "WarmUpSession": true
  },
  "AllowedHosts": "*"
}
