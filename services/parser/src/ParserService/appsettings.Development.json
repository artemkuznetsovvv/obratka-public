{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TasksDb": "Data Source=tasks.db"
  },
  "Browser": {
    "Headless": true
  },
  "RateLimiting": {
    "Sources": {
      "yandex": {
        "MaxConcurrentOrgs": 1,
        "MaxOrgsPerHour": 15,
        "DelayAfterOrgMinMs": 10000,
        "DelayAfterOrgMaxMs": 30000
      }
    }
  },
  "Proxy": {
     "Servers": [
       //{ "Host": "45.134.252.29", "Port": 3000, "Username": "***REMOVED***", "Password": "***REMOVED***" }
     ]
  },
  "TwoGis": {
    "CollectionMode": "Api",
    "ReviewApiKey": "",
    "PageSize": 50,
    "DelayBetweenPagesMinMs": 1000,
    "DelayBetweenPagesMaxMs": 3000,
    "MaxRetries": 3,
    "MaxScrollAttempts": 100,
    "NavigationTimeoutMs": 30000,
    "DefaultCity": "moscow"
  },
  "YandexMaps": {
    "CollectionMode": "BrowserScroll",
    "PageSize": 50,
    "MaxPages": 12,
    "DelayBetweenPagesMinMs": 2000,
    "DelayBetweenPagesMaxMs": 5000,
    "DelayBetweenOrgsMinMs": 10000,
    "DelayBetweenOrgsMaxMs": 30000,
    "MaxRetries": 3,
    "CaptchaSolverApiKey": "",
    "WarmUpSession": false,
    "NavigationTimeoutMs": 240000
  }
}
